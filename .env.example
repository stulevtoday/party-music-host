# Порт сервера
PORT=8080

# Apple Music (MusicKit) — https://developer.apple.com/account/resources/authkeys
# Без этих переменных сервер работает в demo-режиме с mock-каталогом.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8
APPLE_STOREFRONT=ru

# Опциональный ключ для доступа к /host (host-страница: /host/?key=...)
HOST_KEY=
